# ===== Seguridad / API =====
# Token compartido con los ESP. Debe coincidir con SECRET_PAX_API_TOKEN en pax/secrets.h.
# Vacio = endpoint /api/report ABIERTO (no recomendado).
PAX_API_TOKEN=
# Tamano maximo de payload aceptado en /api/report (bytes).
MAX_REPORT_BYTES=524288
# Tope de objetivos por reporte (defensa ante payloads anomalos).
MAX_OBJETIVOS_POR_REPORTE=256
# Purga entidades no vistas en N dias (0 = nunca purgar).
ENTITY_DECAY_DAYS=0

# Telegram alerts
ENABLE_TELEGRAM=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_PROX=60
TELEGRAM_COOLDOWN_SECONDS=300

# Optional OmniStatus integration
ENABLE_OMNISTATUS=0
OMNISTATUS_ENDPOINT=

# MongoDB (misma instancia para eventos y memoria, COLECCIONES separadas)
MONGO_URI=
MONGO_DB=omnistatus
# Eventos (los consume Sentinex/OmniStatus)
MONGO_EVENTS_COLLECTION=events
# Memoria PAX (entidades) -> colección PROPIA, separada de los eventos
MONGO_MEMORY_COLLECTION=pax_memory
MONGO_SERVER_SELECTION_TIMEOUT_MS=2500

# Memoria local de respaldo (se usa solo si NO hay MONGO_URI)
PAX_MEMORY_PATH=memoria_agente.json

# Deteccion local por reglas (solo ETIQUETA dispositivos; alimenta a la IA)
ENABLE_LOCAL_ANALYSIS=1
# 1 = ademas manda alerta directa a Telegram en tiempo real (sin IA).
# 0 = el canal Telegram lo maneja SOLO el cron de IA (recomendado).
ENABLE_REALTIME_ALERTS=0
ALERT_ON_UNKNOWN=1          # desconocido cerca (no recurrente + prox alta)
ALERT_ON_RETURN=1          # recurrente que reaparece tras ausencia
ALERT_ON_NIGHT=1           # actividad en franja horaria inusual
ALERT_ON_CROWD=1           # aglomeracion (muchos dispositivos en un ciclo)
ALERT_RETURN_ABSENCE_MIN=30   # minutos de ausencia para considerar "volvio"
ALERT_CROWD_THRESHOLD=15      # numero de dispositivos por ciclo para aglomeracion
ALERT_QUIET_START=0          # hora local inicio franja inusual
ALERT_QUIET_END=6            # hora local fin franja inusual
ALERT_TZ_OFFSET=0            # offset horas vs UTC (ej. Chile -4)

# ===== Analisis IA -> Telegram (CANAL PRINCIPAL de avisos) =====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini   # modelo configurable
OPENAI_MAX_TOKENS=400
OPENAI_TEMPERATURE=0.3
AI_CRON_INTERVAL_HOURS=3    # corre cada 3 horas
AI_CRON_WINDOW_HOURS=12     # analiza las ultimas 12 horas
# System prompt del analista (configurable; si lo dejas vacio usa el default del codigo)
AI_ANALYSIS_PROMPT=

# Flask port
PORT=5000
